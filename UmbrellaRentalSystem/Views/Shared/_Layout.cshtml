@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UmbrellaRentalSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UmbrellaRentalSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">UmbrellaRentalSystem</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">首頁</a>
                        </li>

                        @* 核心修正：改用 Username 判斷登入，並確認 Role 是不是 Manager *@
                        @if (Context.Session.GetString("Username") != null && Context.Session.GetString("Role")?.ToLower() == "manager")
                        {
                            @* 只有管理員看得到的選單 *@
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Accounts" asp-action="Index">帳號權限管理</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Sponsors" asp-action="Index">贊助者管理</a>
                            </li>
                        }

                        @* 一般使用者與管理員都能看到的雨傘功能 *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Umbrellas" asp-action="Index">瀏覽雨傘地點</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Umbrellas" asp-action="Status">雨傘狀態</a>
                        </li>
                    </ul>

                    @* 右側登入狀態欄 *@
                    <ul class="navbar-nav">
                        @* 修正：改用 Username 判斷是否「未登入」 *@
                        @if (Context.Session.GetString("Username") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-area="" asp-controller="Accounts" asp-action="Login">系統登入</a>
                            </li>
                        }
                        else
                        {
                            @* 已登入狀態 *@
                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    你好，@Context.Session.GetString("Username") (@Context.Session.GetString("Role"))
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-area="" asp-controller="Accounts" asp-action="Logout">登出</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - UmbrellaRentalSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>