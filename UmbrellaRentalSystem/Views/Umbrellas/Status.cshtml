@model IEnumerable<UmbrellaRentalSystem.Models.Umbrella>

@{
    ViewData["Title"] = "雨傘即時狀態";
}

<h2 class="mb-4">雨傘即時狀態清單</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">編號：@item.UmbrellaCode</h5>
                    <p class="card-text">
                        <strong>目前狀態：</strong>
                        @if (item.Status == "Available" || item.Status == "在庫")
                        {
                            <span class="badge bg-success">可借用</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                    </p>
                    <p class="text-dark mb-0">贊助商：@(item.Sponsor != null ? item.Sponsor.SponsorName : "無")</p>
                    <p class="text-dark mb-0">目前地點：@(item.Location != null ? item.Location.LocationName : "無")</p>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">目前沒有任何雨傘資訊。</div>
}