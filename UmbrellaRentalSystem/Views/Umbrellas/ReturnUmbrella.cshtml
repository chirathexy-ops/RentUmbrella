@{
    ViewData["Title"] = "歸還雨傘";
    var myUmbrellas = ViewBag.MyRentedUmbrellasList as List<UmbrellaRentalSystem.Models.Umbrella>;
}

<div class="container" style="margin-top: 30px;">
    @if (myUmbrellas == null || !myUmbrellas.Any())
    {
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="card shadow-sm p-5">
                    <h4 class="fw-bold mb-3">目前沒有借出的雨傘</h4>
                    <p class="text-muted mb-4">你目前沒有尚未歸還的雨傘。</p>
                    <a asp-controller="Accounts" asp-action="UserPage" class="btn btn-outline-secondary w-100">返回使用者頁面</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-lg-7 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white fw-bold">我的借出雨傘</div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>雨傘編號</th>
                                        <th>贊助商</th>
                                        <th>狀態</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in myUmbrellas)
                                    {
                                        bool isSelected = item.UmbrellaCode == ViewBag.SelectedUmbrellaCode;
                                        <tr class="@(isSelected ? "table-warning border-warning" : "")">
                                            <td><span class="badge bg-secondary">#@item.UmbrellaCode</span></td>
                                            <td>@(item.Sponsor?.SponsorName ?? "無")</td>
                                            <td><span class="badge bg-danger">借出中</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-warning text-dark text-center fw-bold">
                        <h4 class="mb-0">歸還雨傘</h4>
                    </div>
                    <div class="card-body p-4">
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                        }

                        <form asp-controller="Umbrellas" asp-action="ReturnUmbrella" method="post">
                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">1. 選擇要歸還的雨傘</label>
                                <select name="umbrellaCode" class="form-select form-control-lg" asp-items="ViewBag.RentedUmbrellas" required>
                                    <option value="">請選擇雨傘</option>
                                </select>
                            </div>

                            <div class="form-group mb-4">
                                <label class="form-label fw-bold">2. 選擇歸還地點</label>
                                <select name="returnLocationId" class="form-select form-control-lg" asp-items="ViewBag.Locations" required>
                                    <option value="">請選擇站點</option>
                                </select>
                            </div>

                            <div class="d-grid gap-2 pt-2">
                                <button type="submit" class="btn btn-warning btn-lg text-dark fw-bold shadow-sm">確認歸還</button>
                                <a asp-controller="Accounts" asp-action="UserPage" class="btn btn-outline-secondary">返回使用者頁面</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>