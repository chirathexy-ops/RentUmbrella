@{
    ViewData["Title"] = "通報雨傘遺失";
}

<div class="row justify-content-center" style="margin-top: 30px;">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-danger text-white text-center">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> 通報雨傘遺失</h4>
            </div>
            <div class="card-body p-4">

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <div class="alert alert-warning small">
                    <strong>注意事項：</strong> 通報遺失後，該雨傘將無法直接歸還，系統將會終止該筆借用交易，請確認後再送出。
                </div>

                <form asp-controller="Umbrellas" asp-action="ReportLost" method="post">

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold text-danger">請選擇您目前遺失的雨傘編號</label>
                        <select name="umbrellaId" class="form-select form-control-lg" asp-items="ViewBag.MyRentedUmbrellas" required>
                            <option value="">-- 請選擇您手上遺失的雨傘 --</option>
                        </select>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold">遺失地點或情況說明 (選填)</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="例如：大約下午1點不小心掉在圖書館、忘在學餐..."></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm" onclick="return confirm('確定要通報這把雨傘遺失嗎？送出後將變更系統狀態。')">
                            確認送出通報
                        </button>
                        <a asp-controller="Umbrellas" asp-action="Index" class="btn btn-outline-secondary">
                            返回首頁
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>