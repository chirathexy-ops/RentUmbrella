@model UmbrellaRentalSystem.Models.Umbrella

@{
    ViewData["Title"] = "編輯雨傘";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <!-- 編輯卡片 -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white p-3 rounded-top">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>編輯雨傘資訊
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- 隱藏主鍵 -->
                        <input type="hidden" asp-for="UmbrellaId" />

                        <!-- 雨傘編號 -->
                        <div class="form-floating mb-3">
                            <input asp-for="UmbrellaCode" class="form-control bg-light" readonly placeholder="雨傘編號" />
                            <label asp-for="UmbrellaCode">雨傘編號 (Umbrella Code)</label>
                            <span asp-validation-for="UmbrellaCode" class="text-danger small"></span>
                        </div>

                        <!-- 雨傘狀態 -->
                        <div class="form-floating mb-3">
                            <select asp-for="Status" class="form-select">
                                <option value="Available">Available (在庫/可借出)</option>
                                <option value="Rented">Rented (借出中)</option>
                                <option value="Lost">Lost (遺失)</option>
                            </select>
                            <label asp-for="Status">雨傘狀態</label>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <!-- 目前地點 -->
                        <div class="form-floating mb-3">
                            <select asp-for="LocationId" class="form-select" asp-items="ViewBag.LocationId">
                                <option value="">-- 請選擇地點 --</option>
                            </select>
                            <label asp-for="LocationId">放置地點</label>
                            <span asp-validation-for="LocationId" class="text-danger small"></span>
                        </div>

                        <!-- 贊助商 -->
                        <div class="form-floating mb-4">
                            <select asp-for="SponsorId" class="form-select" asp-items="ViewBag.SponsorId">
                                <option value="">-- 請選擇贊助商 --</option>
                            </select>
                            <label asp-for="SponsorId">贊助單位</label>
                            <span asp-validation-for="SponsorId" class="text-danger small"></span>
                        </div>

                        <!-- 按鈕區 -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 me-md-2">
                                <i class="bi bi-arrow-left me-1"></i>返回列表
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">
                                <i class="bi bi-check-lg me-1"></i>儲存變更
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}