@model UmbrellaRentalSystem.Models.Umbrella

@{
    ViewData["Title"] = "雨傘詳情";
}

<h1>雨傘詳情</h1>

<div>
    <h4>Umbrella</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">資料庫編號</dt>
        <dd class="col-sm-10">@Model.UmbrellaId</dd>
        <dt class="col-sm-2">雨傘編號</dt>
        <dd class="col-sm-10">@Model.UmbrellaCode</dd>
        <dt class="col-sm-2">狀態</dt>
        <dd class="col-sm-10">@Model.Status</dd>
        <dt class="col-sm-2">地點</dt>
        <dd class="col-sm-10">@(Model.Location?.LocationName ?? Model.LocationId.ToString())</dd>
        <dt class="col-sm-2">贊助商</dt>
        <dd class="col-sm-10">@(Model.Sponsor?.SponsorName ?? Model.SponsorId.ToString())</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.UmbrellaId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>