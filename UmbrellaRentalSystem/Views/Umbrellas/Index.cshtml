@model IEnumerable<UmbrellaRentalSystem.Models.Umbrella>

@{
    ViewData["Title"] = "雨傘管理中心";
    int? currentLocationId = ViewBag.CurrentLocation as int?;
    bool isManager = ViewBag.IsManager == true;
    bool isUserLoggedIn = ViewBag.IsUserLoggedIn == true;
}

<h1 class="mb-4">☔ 雨傘借還管理系統</h1>

<div class="d-flex justify-content-between mb-3">
    <div>
        @if (isManager)
        {
            <a asp-action="Create" class="btn btn-primary">➕ 新增雨傘資料</a>
        }
        @if (isUserLoggedIn)
        {
            <a asp-action="ReturnUmbrella" class="btn btn-warning font-weight-bold text-dark">🔍 我的借傘狀態 / 歸還雨傘</a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>@TempData["SuccessMessage"]</strong>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>@TempData["ErrorMessage"]</strong>
    </div>
}

<div class="row">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white font-weight-bold">
                📍 站點位置篩選
            </div>
            <div class="list-group list-group-flush">
                <a asp-action="Index" asp-route-locationId=""
                   class="list-group-item list-group-item-action @(currentLocationId == null ? "active font-weight-bold" : "")">
                    🌐 顯示所有站點
                </a>
                @if (ViewBag.Locations != null)
                {
                    foreach (var loc in ViewBag.Locations)
                    {
                        <a asp-action="Index" asp-route-locationId="@loc.LocationId"
                           class="list-group-item list-group-item-action @(currentLocationId == loc.LocationId ? "active font-weight-bold" : "")">
                            🏢 @loc.LocationName
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>雨傘編號</th>
                            <th>目前狀態</th>
                            <th>所在站點位置</th>
                            <th>贊助商名稱</th>
                            @if (isManager || isUserLoggedIn)
                            {
                                <th class="text-center">操作項目</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="@(isManager || isUserLoggedIn ? 5 : 4)" class="text-center text-muted py-4">
                                    ❌ 該站點目前沒有任何雨傘資料。
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-secondary" style="vertical-align: middle;">
                                        # @item.UmbrellaId
                                    </td>
                                    <td style="vertical-align: middle;">
                                        @if (item.Status == "Available")
                                        {
                                            <span class="badge bg-success text-white px-2 py-1">在庫 (Available)</span>
                                        }
                                        else if (item.Status == "Rented")
                                        {
                                            <span class="badge bg-secondary text-white px-2 py-1">已借出 (Rented)</span>
                                        }
                                        else if (item.Status == "Lost")
                                        {
                                            <span class="badge bg-danger text-white px-2 py-1">遺失 (Lost)</span>
                                        }
                                    </td>
                                    <td class="text-info font-weight-bold" style="vertical-align: middle;">
                                        @(item.Location != null ? item.Location.LocationName : "⚠️ 已被借出外在")
                                    </td>
                                    <td class="text-dark font-weight-bold" style="vertical-align: middle;">
                                        @(item.Sponsor != null ? item.Sponsor.SponsorName : "無")
                                    </td>

                                    @if (isManager || isUserLoggedIn)
                                    {
                                        <td class="text-center" style="vertical-align: middle;">
                                            @if (isManager)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.UmbrellaId" class="btn btn-sm btn-outline-primary">編輯</a> <span>|</span>
                                                <a asp-action="Details" asp-route-id="@item.UmbrellaId" class="btn btn-sm btn-outline-info">詳情</a> <span>|</span>
                                                <a asp-action="Delete" asp-route-id="@item.UmbrellaId" class="btn btn-sm btn-outline-danger">刪除</a>
                                            }
                                            else if (isUserLoggedIn)
                                            {
                                                @if (item.Status == "Available")
                                                {
                                                    <form asp-action="RentUmbrella" method="post" style="display:inline;">
                                                        <input type="hidden" name="umbrellaId" value="@item.UmbrellaId" />
                                                        <button type="submit" class="btn btn-sm btn-success font-weight-bold px-3">
                                                            🔘 立即借傘
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">借出中</span>
                                                }
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>