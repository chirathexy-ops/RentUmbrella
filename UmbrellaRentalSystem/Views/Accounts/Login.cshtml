@model UmbrellaRentalSystem.Models.Account

@{
    ViewData["Title"] = "管理員登入";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-4">
        <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white text-center">
                <h4 class="mb-0">管理員登入</h4>
            </div>
            <div class="card-body p-4">
                <form asp-controller="Accounts" asp-action="Login" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">管理員帳號</label>
                        <input type="text" name="username" class="form-control" placeholder="請輸入 Name" required />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold">登入密碼</label>
                        <input type="password" name="password" class="form-control" placeholder="請輸入 Password" required />
                    </div>

                    <div class="form-group d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">登入系統</button>
                    </div>

                   
                </form>
            </div>
        </div>
    </div>
</div>
