@model UmbrellaRentalSystem.Models.Sponsor

@{
    ViewData["Title"] = "刪除贊助商";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <!-- 刪除警告卡片 -->
            <div class="card shadow-sm border-0 rounded-3">
                <!-- 紅色警告標頭 -->
                <div class="card-header bg-danger text-white p-3 rounded-top">
                    <h4 class="mb-0 fw-bold">確定要刪除這個贊助商嗎？</h4>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted small mb-3">刪除後資料將無法復原，請確認以下贊助商資訊：</p>

                    <!-- 資訊顯示列表 -->
                    <div class="list-group list-group-flush mb-4 border rounded">
                        <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <span class="text-muted">贊助商名稱</span>
                            <span class="fw-bold text-dark">@Model.SponsorName</span>
                        </div>
                    </div>

                    <!-- 刪除表單與按鈕 -->
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="SponsorId" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 me-md-2">
                                返回列表
                            </a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">
                                確認刪除
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>