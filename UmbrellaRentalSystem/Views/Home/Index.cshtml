@{
    ViewData["Title"] = "雨傘租借管理系統";
}

<div class="text-center">
    <h1 class="display-4">歡迎使用雨傘租借系統</h1>
    <p class="lead">請選擇您要進行的操作</p>
    <hr />

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">使用者借還傘</h5>
                    <p class="card-text">輸入卡號登入後，進行借傘與還傘操作。</p>
                    <a asp-controller="Accounts" asp-action="UserLogin" class="btn btn-info text-white">使用者登入</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">管理員系統</h5>
                    <p class="card-text">管理系統後台人員帳號與權限。</p>
                    <a asp-controller="Accounts" asp-action="Index" class="btn btn-primary">進入管理</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mt-4 mt-md-0">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">贊助者管理</h5>
                    <p class="card-text">檢視與編輯提供雨傘的贊助廠商資料。</p>
                    <a asp-controller="Sponsors" asp-action="Index" class="btn btn-success">進入管理</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mt-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">雨傘清單</h5>
                    <p class="card-text">查看所有雨傘的即時狀態與目前地點。</p>
                    <a asp-controller="Umbrellas" asp-action="Index" class="btn btn-info text-white">進入管理</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s;
    }
    .card:hover {
        transform: scale(1.05);
    }
</style>
